# Общие настройки
PROJECT_NAME=CMAS
ENVIRONMENT=development

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL - Users Service
USERS_DB_HOST=users_db
USERS_DB_PORT=5432
USERS_DB_NAME=users_db
USERS_DB_USER=postgres
USERS_DB_PASSWORD=postgres

# PostgreSQL - Rooms Service
ROOMS_DB_HOST=rooms_db
ROOMS_DB_PORT=5432
ROOMS_DB_NAME=rooms_db
ROOMS_DB_USER=postgres
ROOMS_DB_PASSWORD=postgres

# PostgreSQL - Requests Service
REQUESTS_DB_HOST=requests_db
REQUESTS_DB_PORT=5432
REQUESTS_DB_NAME=requests_db
REQUESTS_DB_USER=postgres
REQUESTS_DB_PASSWORD=postgres

# Сервисы (внутренние URL для docker-compose)
USERS_SERVICE_URL=http://users_service:8001
ROOMS_SERVICE_URL=http://rooms_service:8002
REQUESTS_SERVICE_URL=http://requests_service:8003
GATEWAY_URL=http://gateway:8000

# Порты (внешние, для локального доступа)
GATEWAY_PORT=8000
USERS_SERVICE_PORT=8001
ROOMS_SERVICE_PORT=8002
REQUESTS_SERVICE_PORT=8003
